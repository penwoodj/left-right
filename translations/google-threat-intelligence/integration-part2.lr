# ============================================================================
# Original JS:
```javascript
const makeHumanReadable = flow(replace(/\./g, ' '), replace(/_/g, ' '), startCase);
```

# Left-Right translation:
{ path: _<@0,
  path
    `.`: ` `          # Replace dots with spaces
    `_`: ` `          # Replace underscores with spaces
    "^_"              # Capitalize each word
}

# ============================================================================
# _processLookupItem
# ============================================================================
# Original JS:
```javascript
const _processLookupItem = (
  type,
  result,
  entity,
  showEntitiesWithNoDetections,
  showNoInfoTag
) => {
  if (result && result.__keyLimitReached) {
    return {
      entity,
      data: null
    };
  }

  const data = fp.get('data', result);
  const attributes = fp.get('attributes', data);
  const lastAnalysisStats = fp.get('last_analysis_stats', attributes);
  const totalResults = fp.flow(
    fp.pick(['undetected', 'malicious', 'suspicious', 'harmless']),
    fp.values,
    fp.sum
  )(lastAnalysisStats);
  const totalMalicious = fp.get('malicious', lastAnalysisStats);

  // Check for no data
  if (!result || !data || !totalResults) {
    if (showNoInfoTag) {
      return {
        entity,
        data: {
          summary: ['has not seen or scanned'],
          details: {
            noInfoMessage: true
          }
        }
      };
    } else {
      return {
        entity,
        data: null
      };
    }
  }

  // No positive detections and user wants to hide them
  if (!totalMalicious && !showEntitiesWithNoDetections) {
    return {
      entity,
      data: null
    };
  }

  const scans = fp.flow(
    fp.get('last_analysis_results'),
    map((scanResult, scanName) => ({
      name: scanName,
      detected: scanResult.category === 'malicious',
      result:
        !scanResult.result && scanResult.category === 'type-unsupported'
          ? 'type-unsupported'
          : ['clean', 'suspicious', 'malware', 'malicious', 'unrated'].includes(
              scanResult.result
            )
          ? fp.capitalize(scanResult.result)
          : scanResult.result
    }))
  )(attributes);

  const verdict = fp.flow(
    fp.get('gti_assessment.verdict.value'),
    fp.replace('VERDICT_', ''),
    fp.capitalize
  )(attributes);

  const coreLink = `https://www.virustotal.com/gui/${fp.replace('_', '-', data.type)}/${
    data.id
  }`;

  const detailsTab = getDetailFields(DETAILS_FORMATS[type], attributes);

  return {
    entity,
    data: {
      summary: [`Verdict: ${verdict}`],
      details: {
        type,
        detectionsLink: `${coreLink}/detection`,
        relationsLink: `${coreLink}/relations`,
        detailsLink: `${coreLink}/details`,
        communityLink: `${coreLink}/community`,
        behaviorLink: `${coreLink}/behavior`,
        total: totalResults,
        reputation: attributes.reputation,
        scan_date: new Date(attributes.last_modification_date * 1000),
        positives: totalMalicious,
        positiveScans: fp.flow(
          fp.filter(fp.get('detected')),
          fp.orderBy('result', 'desc')
        )(scans),
        names: attributes.names,
        negativeScans: fp.flow(
          fp.filter(({ detected }) => !detected),
          fp.orderBy('result', 'desc')
        )(scans),
        detailsTab,
        tags: attributes.tags,
        gtiAssessment: fp.get('gti_assessment', attributes),
        verdict,
      }
    }
  };
};
```

# Left-Right translation:
{ type: _<@0, result: _<@1, entity: _<@2,
  showEntitiesWithNoDetections: _<@3, showNoInfoTag: _<@4,

  # Check for API limit
  { result@`__keyLimitReached` }: { entity, data: null },

  data: result@`data`,
  attributes: data@`attributes`,
  lastAnalysisStats: attributes@`last_analysis_stats`,
  totalResults: lastAnalysisStats
    @0 { `undetected`, `malicious`, `suspicious`, `harmless` }
    @0 @sum,
  totalMalicious: lastAnalysisStats@`malicious`,

  # No data case
  { (!result) || (!data) || (!totalResults):
    { showNoInfoTag }:
      {
        entity,
        data: {
          summary: [`has not seen or scanned`],
          details: { noInfoMessage: true }
        }
      }
      :
      { entity, data: null }
  ,

  # No detections case
  { (!totalMalicious) && (!showEntitiesWithNoDetections):
    { entity, data: null }
  ,

  # Format scan results
  scans: attributes@`last_analysis_results`
    ${ { scanResult: _<, scanName: _<,
        name: scanName,
        detected: scanResult@`category` = `malicious`,
        result: {
          (!scanResult@`result`) && (scanResult@`category` = `type-unsupported`):
            `type-unsupported`,
          [`clean`, `suspicious`, `malware`, `malicious`, `unrated`] >< scanResult@`result`:
            scanResult@`result` "^_",
          scanResult@`result`
        }
      }
    }
  ,

  # Format verdict
  verdict: attributes@[\`gti_assessment\`][\`verdict\`][\`value`\`]
    `VERDICT_`: ``
    "^_",

  # Build core link
  coreLink: \`https://www.virustotal.com/gui/\${data@`type`:`_`}/\${data@`id`}\`,

  # Get detail fields
  detailsTab: getDetailFields(DETAILS_FORMATS@type, attributes),

  # Return formatted result
  {
    entity,
    data: {
      summary: [\`Verdict: \${verdict}\`],
      details: {
        type,
        detectionsLink: \`coreLink/detection\`,
        relationsLink: \`coreLink/relations\`,
        detailsLink: \`coreLink/details\`,
        communityLink: \`coreLink/community\`,
        behaviorLink: \`coreLink/behavior\`,
        total: totalResults,
        reputation: attributes@`reputation`,
        scan_date: Date(attributes@`last_modification_date` * 1000),
        positives: totalMalicious,
        positiveScans: scans ?{ _<@`detected` } sortBy `result` desc,
        names: attributes@`names`,
        negativeScans: scans ?{ !(_<@`detected`) } sortBy `result` desc,
        detailsTab,
        tags: attributes@`tags`,
        gtiAssessment: attributes@`gti_assessment`,
        verdict
      }
    }
  }
}

