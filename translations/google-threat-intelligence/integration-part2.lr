  # Async request for threat actors
  searchResult: asyncRequestWithDefaults({
    uri: `https://www.virustotal.com/api/v3/collections`,
    qs: {
      filter: `collection_type:threat-actor`,
      attributes: `name`,
      limit: 40,
      { cursor }: { cursor }
    },
    options
  })@`body`,

  # Extract threat actor names
  threatActorNames: searchResult@`data` ${ _<@`attributes`@`name` },

  # Get next cursor and aggregate
  nextCursor: searchResult@[\`meta\`][\`cursor\`],
  nextAgg: agg + threatActorNames,

  # Recursive call if more pages
  { nextCursor }:
    getAndCacheAllThreatActorNames(options, nextCursor, nextAgg),

  # Final result: dedupe and sort
  threatActorNames: nextAgg
    ~
    sortBy { _<: _< `'_` }
}
