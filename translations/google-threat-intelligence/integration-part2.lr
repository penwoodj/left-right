# ============================================================================
# groupByConfidence
# ============================================================================
# Original JS:
```javascript
const groupByConfidence = (association) => {
  const hasConfidenceArray = (association, property) =>
    isArray(association[property]) &&
    size(association[property]) > 0 &&
    isPlainObject(association[property][0]) &&
    some(
      (obj) => obj && isPlainObject(obj) && has('confidence', obj),
      association[property]
    );

  const confidenceFields = [
    'motivations',
    'tags_details',
    'malware_roles',
    'available_mitigation',
    'vendor_fix_references',
    'source_regions_hierarchy',
    'targeted_regions_hierarchy',
    'targeted_industries_tree',
    'merged_actors'
  ];

  const groupedConfidenceData = reduce(
    (agg, field) => ({
      ...agg,
      ...(hasConfidenceArray(association, field) && {
        [field]: groupBy('confidence', association[field])
      })
    }),
    {},
    confidenceFields
  );

  // Collect all unique confidence values
  const uniqueConfidences = flow(
    reduce((acc, field) => assign(acc, groupedConfidenceData[field]), {}),
    mapValues((val) => (isEmpty(val) ? undefined : val)),
    omitBy(isUndefined),
    keys,
    uniq
  )(confidenceFields);

  if (!size(uniqueConfidences)) return;

  // For each confidence, collect values from each field
  const threatsGroupedByConfidence = reduce(
    (agg, confidence) => {
      const getUniqueValuesInGroup = flow(
        get(confidence),
        map('value'),
        uniq,
        filter((x) => !['null', null, 'undefined', undefined].includes(x)),
        compact
      );

      const formatRegion = flow(
        get(confidence),
        filter(
          (x) =>
            !['null', null, 'undefined', undefined].includes(x.country) &&
            !['null', null, 'undefined', undefined].includes(x.country_iso2) &&
            !['null', null, 'undefined', undefined].includes(x.sub_region) &&
            !['null', null, 'undefined', undefined].includes(x.region)
        ),
        map(
          (region) =>
            `${region.country || region.country_iso2}${
              (region.country || region.country_iso2) &&
              (region.sub_region || region.region)
                ? ', '
                : ''
            } ${region.sub_region || region.region}`
        ),
        uniq,
        compact
      );

      // Extract each field type for this confidence level
      const motivationsContent = getUniqueValuesInGroup(
        groupedConfidenceData.motivations
      );
      const motivations = size(motivationsContent) && {
        motivations: motivationsContent
      };

      const tags = size(groupedConfidenceData.tags_details) && {
        tags: getUniqueValuesInGroup(groupedConfidenceData.tags_details)
      };

      const malwareRolesContent = getUniqueValuesInGroup(
        groupedConfidenceData.malware_roles
      );
      const malwareRoles = size(malwareRolesContent) && {
        malwareRoles: malwareRolesContent
      };

      const availableMitigationContent = getUniqueValuesInGroup(
        groupedConfidenceData.available_mitigation
      );
      const availableMitigation = size(availableMitigationContent) && {
        availableMitigation: availableMitigationContent
      };

      const vendorFixReferencesContent = getUniqueValuesInGroup(
        groupedConfidenceData.vendor_fix_references
      );
      const vendorFixReferences = size(vendorFixReferencesContent) && {
        vendorFixReferences: vendorFixReferencesContent
      };

      const sourceRegionsContent = formatRegion(
        groupedConfidenceData.source_regions_hierarchy
      );
      const sourceRegions = size(sourceRegionsContent) && {
        sourceRegions: sourceRegionsContent
      };

      const targetedRegionsContent = formatRegion(
        groupedConfidenceData.targeted_regions_hierarchy
      );
      const targetedRegions = size(targetedRegionsContent) && {
        targetedRegions: targetedRegionsContent
      };

      const targetedIndustriesContent = getUniqueValuesInGroup(
        groupedConfidenceData.targeted_industries_tree
      );
      const targetedIndustries = size(groupedConfidenceData.targeted_industries_tree) && {
        targetedIndustries: targetedIndustriesContent
      };

      const mergedActorsContent = getUniqueValuesInGroup(
        groupedConfidenceData.merged_actors
      );
      const mergedActors = size(mergedActorsContent) && {
        mergedActors: mergedActorsContent
      };

      return {
        ...agg,
        [confidence]: {
          ...motivations,
          ...tags,
          ...malwareRoles,
          ...availableMitigation,
          ...vendorFixReferences,
          ...sourceRegions,
          ...targetedRegions,
          ...targetedIndustries,
          ...mergedActors
        }
      };
    },
    {},
    uniqueConfidences
  );

  return threatsGroupedByConfidence;
};
```

# Left-Right translation:
# Note: This is a complex reduce operation. In LR, we use reduce operator directly.
{ association: _<@0,
  # Helper to check if property has confidence array
  hasConfidenceArray: { property: _<@1,
    {
      (association@[\`{property}\`] ?= `list`):
      (association@[\`{property}\`] # > 0):
      (association@[\`{property}\`]@0 ?= `map`):
      (association@[\`{property}\`] ?|{ _<@`confidence` })
    }
  },

  # All confidence fields to process
  confidenceFields: [
    `motivations`, `tags_details`, `malware_roles`, `available_mitigation`,
    `vendor_fix_references`, `source_regions_hierarchy`, `targeted_regions_hierarchy`,
    `targeted_industries_tree`, `merged_actors`
  ],

  # Group data by confidence for each field
  groupedConfidenceData: confidenceFields
    reduce { agg: _<, field: _<,
      {
        ...agg,
        {
          hasConfidenceArray(field):
            { [\`{field}\`]: association@[\`{field}\`] groupBy `confidence` }
        }
      }
    },

  # Extract unique confidence values across all fields
  uniqueConfidences: confidenceFields
    reduce { acc: _<, field: _<,
      acc + groupedConfidenceData@[\`{field}\`]
    }
    { _<@0 } # > 0: _<, undefined }
    ?{ _< ?= `undefined` }
    @0

  # Only proceed if we have confidences
  threatsGroupedByConfidence: {
    uniqueConfidences # = 0:
    uniqueConfidences
      reduce { agg: _<, confidence: _<,
        # Helper to get unique values from a confidence group
        getUniqueValuesInGroup: { field: _<@1,
          groupedConfidenceData@[\`{confidence}\`][\`{field}\`]
            ${ _<@`value` }
            ~
            ?{ ![`null`, null, `undefined`, undefined] >< _< }
            ?{ _< } #
        },

        # Helper to format region names
        formatRegion: { field: _<@1,
          groupedConfidenceData@[\`{confidence}\`][\`{field}\`]
            ?{ ![`null`, null, `undefined`, undefined] >< _<@`country` }
              ?{ ![`null`, null, `undefined`, undefined] >< _<@`country_iso2` }
              ?{ ![`null`, null, `undefined`, undefined] >< _<@`sub_region` }
              ?{ ![`null`, null, `undefined`, undefined] >< _<@`region` }
            ${ { region: _<,
              country: region@`country` ?? region@`country_iso2`,
              subRegion: region@`sub_region` ?? region@`region`,
              {
                country: { subRegion: `country, {subRegion}` }{ country },
                subRegion: { country: subRegion }
              }
            }
            ~
            ?{ _< } #
        },

        # Extract each field type for this confidence
        motivations: { getUniqueValuesInGroup(`motivations`) # > 0 }: { motivations: getUniqueValuesInGroup(`motivations`) },
        tags: { groupedConfidenceData@`tags_details` # > 0 }: { tags: getUniqueValuesInGroup(`tags_details`) },
        malwareRoles: { getUniqueValuesInGroup(`malware_roles`) # > 0 }: { malwareRoles: getUniqueValuesInGroup(`malware_roles`) },
        availableMitigation: { getUniqueValuesInGroup(`available_mitigation`) # > 0 }: { availableMitigation: getUniqueValuesInGroup(`available_mitigation`) },
        vendorFixReferences: { getUniqueValuesInGroup(`vendor_fix_references`) # > 0 }: { vendorFixReferences: getUniqueValuesInGroup(`vendor_fix_references`) },
        sourceRegions: { formatRegion(`source_regions_hierarchy`) # > 0 }: { sourceRegions: formatRegion(`source_regions_hierarchy`) },
        targetedRegions: { formatRegion(`targeted_regions_hierarchy`) # > 0 }: { targetedRegions: formatRegion(`targeted_regions_hierarchy`) },
        targetedIndustries: { groupedConfidenceData@`targeted_industries_tree` # > 0 }: { targetedIndustries: getUniqueValuesInGroup(`targeted_industries_tree`) },
        mergedActors: { getUniqueValuesInGroup(`merged_actors`) # > 0 }: { mergedActors: getUniqueValuesInGroup(`merged_actors`) },

        # Combine all for this confidence level
        ...agg,
        { [\`{confidence}\`]: motivations + tags + malwareRoles + availableMitigation + vendorFixReferences + sourceRegions + targetedRegions + targetedIndustries + mergedActors }
      },
    }
  }
}

# ============================================================================
# flattenWithPaths
# ============================================================================
# Original JS:
```javascript
const flattenWithPaths = (entity, obj) => {
  // Convert empty object to null
  if (Object.keys(obj).length === 0) {
    return null;
  }

  const traverse = curry((path, val) => {
    const isPlainObjectWithNoNested =
      isPlainObject(val) && !some((v) => isPlainObject(v) || isArray(v), values(val));

    if (isPlainObjectWithNoNested) return [{ ...val, path: path.join('.') }];

    const isArrayWithNoNested =
      isArray(val) && !some((v) => isPlainObject(v) || isArray(v), val);

    if (isArrayWithNoNested) return [{ values: val, path: path.join('.') }];

    const isPlainObjectWithNested =
      isPlainObject(val) && some((v) => isPlainObject(v) || isArray(v), values(val));

    if (isPlainObjectWithNested) {
      return flow(
        toPairs,
        flatMap(([key, value]) => traverse([...path, key], value))
      )(val);
    }

    const isArrayWithNested =
      isArray(val) && some((v) => isPlainObject(v) || isArray(v), val);

    if (isArrayWithNested) {
      return flow(
        entries,
        flatMap(([_, value]) => traverse([...path], value))
      )(val);
    }

    return [{ value: val, path: path.join('.') }];
  });

  const flattenedListOfObjects = traverse([], obj);
  const sortedListOfValues = sortByEntityPresenceAndPrevalence(
    entity,
    flattenedListOfObjects
  );

  return sortedListOfValues;
};
```

# Left-Right translation:
# Note: Recursion with curry - LR supports recursive operator definitions
{ entity: _<@0, obj: _<@1,
  # Return null for empty object
  { obj @0 # = 0 }: null,

  # Curried recursive traverse operator
  traverse: { path: _<@1, val: _<@2,
    # Check: plain object with no nested objects/arrays
    isPlainObjectWithNoNested: {
      (val ?= `map`):
      !(val @0 ?|{ _< ?= `map` } || _< ?= `list` })
    },

    { isPlainObjectWithNoNested }: [ ...val, path: path >< `.` ],

    # Check: array with no nested objects/arrays
    isArrayWithNoNested: {
      (val ?= `list`):
      !(val ?|{ _< ?= `map` } || _< ?= `list` })
    },

    { isArrayWithNoNested }: [ { values: val, path: path >< `.` } ],

    # Check: plain object with nested objects/arrays
    isPlainObjectWithNested: {
      (val ?= `map`):
      (val @0 ?|{ _< ?= `map` } || _< ?= `list` })
    },

    { isPlainObjectWithNested }:
      val toPairs
        ${ { key: _<@0, value: _<@1,
            traverse([...path, key], value)
          }
        } ~,

    # Check: array with nested objects/arrays
    isArrayWithNested: {
      (val ?= `list`):
      (val ?|{ _< ?= `map` } || _< ?= `list` })
    },

    { isArrayWithNested }:
      val entries
        ${ { _: _<@0, value: _<@1,
            traverse([...path], value)
          }
        } ~,

    # Default: primitive value
    [{ value: val, path: path >< `.` }]
  },

  # Start traversal from empty path
  flattenedListOfObjects: traverse([], obj),

  # Sort and group by entity presence
  sortedListOfValues: sortByEntityPresenceAndPrevalence(entity, flattenedListOfObjects)
}

# ============================================================================
# sortByEntityPresenceAndPrevalence
# ============================================================================
# Original JS:
```javascript
const sortByEntityPresenceAndPrevalence = (entity, arrayOfObjects) =>
  flow(
    compact, // 1) remove falsey
    uniqBy('value'), // 2) de-dupe on value
    map((obj) => ({
      // 3) decorate each record
      ...obj,
      readablePath: makeHumanReadable(obj.path),
      matchesSubstring: hasSubstringInValue(obj, entity.value)
    })),
    sortBy((o) => -(o.prevalence || 0)), // 4) high prevalence first
    sortBy((o) => (o.matchesSubstring ? 0 : 1)), // 5) hits on entity first
    groupBy('readablePath'), // 6) → { key: [records] }
    mapValues((records) => {
      /* 7) wrap each group:
         {
           data: [ …records ],
           averageLength: <rounded-up mean length of record.value>
         }
      */
      const lengths = records
        .filter(has('value')) // only items with a `value` field
        .map((r) => String(r.value).length); // length in characters

      const avg = lengths.length
        ? Math.ceil(mean(lengths)) // round -> nearest higher int
        : 0; // empty group → 0

      return { data: records, averageLength: avg };
    })
  )(arrayOfObjects);
```

# Left-Right translation:
{ entity: _<@0, arrayOfObjects: _<@1,
  arrayOfObjects
    ?{ _< } #             # 1) Remove falsy
    ~@`value`              # 2) Unique by value
    ${ { obj: _<,           # 3) Decorate each record
        ...obj,
        readablePath: makeHumanReadable(obj@`path`),
        matchesSubstring: hasSubstringInValue(obj, entity@`value`)
      }
    }
    sortBy { _<: -(_<@`prevalence` ?? 0) }      # 4) High prevalence first
    sortBy { _<: _<@`matchesSubstring` ? 0 : 1 }        # 5) Entity hits first
    groupBy `readablePath`    # 6) Group by readable path

    # 7) Wrap each group with data and averageLength
    mapValues { records: _<,
      lengths: records ?{ _<@`value` } ${ _< # },
      avg: { lengths # > 0 }: mean(lengths)^{ }, 0,    # Round up
      { data: records, averageLength: avg }
    }
}

# ============================================================================
# hasSubstringInValue
# ============================================================================
# Original JS:
```javascript
const hasSubstringInValue = ({ value: val }, substring) =>
  includes(substring.toLowerCase(), (isString(val) ? val : String(val)).toLowerCase());
```

# Left-Right translation:
{ val: _<@`value`, substring: _<@1,
  substring
    `'_`
    >< (val ?= `text` ? val : val\`text\`)
    `'_`
    ><
}

