    uri: \`https://www.virustotal.com/api/v3/files/{entity@value}/behaviour_summary\`,
    method: `GET`,
    headers: { \`x-apikey\`: options@apiKey }
  },

  # Execute request (async)
  requestWithDefaults(behaviourSummaryOptions)
    { err: _<, response: _<, body: _<,
      _handleRequestError(err, response, body, options)
        { err: _<, result: _<,
          { err }: reject(err),

          # Return data or empty array
          { result@`data`: result@`data`, [] }
        }
    }
}

# ============================================================================
# onMessage
# ============================================================================
# Original JS:
```javascript
async function onMessage(payload, options, cb) {
  const { entity, action } = payload;
  switch (action) {
    case 'GET_RELATIONS':
      try {
        const relations = await getRelations(entity, options);
        Logger.trace({ relations }, 'GET_RELATIONS');
        cb(null, relations);
      } catch (error) {
        cb(error);
      }
      break;
    case 'GET_BEHAVIORS':
      try {
        const behaviors = await getBehaviors(entity, options);
        Logger.trace({ behaviors }, 'GET_BEHAVIORS');
        cb(null, behaviors);
      } catch (error) {
        cb(error);
      }
      break;
    case 'GET_WHOIS':
      try {
        const whois = await getWhois(entity, options);
        Logger.trace({ whois }, 'GET_WHOIS');
        cb(null, whois);
      } catch (error) {
        cb(error);
      }
      break;
    case 'GET_THREATS':
      try {
        const threatResults = await lookupThreatsAsync(entity, options);

        const associationLink = `https://www.virustotal.com/gui/${getUiUrlByEntityType(
          entity
        )}`;

        Logger.trace({ threatResults }, 'GET_THREATS');
        cb(null, { threatResults, associationLink });
      } catch (error) {
        cb(error);
      }
      break;
    case 'GET_REPORTS':
      try {
        const reportResults = await lookupReportsAsync(entity, options);

        const associationLink = `https://www.virustotal.com/gui/${getUiUrlByEntityType(
          entity
        )}`;

        Logger.trace({ reportResults }, 'GET_REPORTS');
        cb(null, { reportResults, associationLink });
      } catch (error) {
        cb(error);
      }
      break;
  }
}
```

# Left-Right translation:
{ payload: _<@0, options: _<@1, cb: _<@2,
  entity: payload@`entity`,
  action: payload@`action`,

  # Switch on action type
  {
    action = `GET_RELATIONS`:
      {
        relations: getRelations(entity, options),
        Logger.trace(relations, `GET_RELATIONS`),
        cb(null, relations)
      },
    action = `GET_BEHAVIORS`:
      {
        behaviors: getBehaviors(entity, options),
        Logger.trace(behaviors, `GET_BEHAVIORS`),
        cb(null, behaviors)
      },
    action = `GET_WHOIS`:
      {
        whois: getWhois(entity, options),
        Logger.trace(whois, `GET_WHOIS`),
        cb(null, whois)
      },
    action = `GET_THREATS`:
      {
        threatResults: lookupThreatsAsync(entity, options),
        associationLink: \`https://www.virustotal.com/gui/{getUiUrlByEntityType(entity)}\`,
        Logger.trace(threatResults, `GET_THREATS`),
        cb(null, { threatResults, associationLink })
      },
    action = `GET_REPORTS`:
      {
        reportResults: lookupReportsAsync(entity, options),
        associationLink: \`https://www.virustotal.com/gui/{getUiUrlByEntityType(entity)}\`,
        Logger.trace(reportResults, `GET_REPORTS`),
        cb(null, { reportResults, associationLink })
      }
  }
}

# ============================================================================
# validateOptions
# ============================================================================
# Original JS:
```javascript
async function validateOptions(userOptions, cb) {
  let errors = [];
  if (
    typeof userOptions.apiKey.value !== 'string' ||
    (typeof userOptions.apiKey.value === 'string' &&
      userOptions.apiKey.value.length === 0)
  ) {
    errors.push({
      key: 'apiKey',
      message: 'You must provide a GTI API key'
    });
  }

  let maxHashesPerGroup = userOptions.maxHashesPerGroup.value;
  if (_.isNaN(maxHashesPerGroup) || maxHashesPerGroup <= 0) {
    errors.push({
      key: 'maxHashesPerGroup',
      message: 'Maximum number of hashes per lookup request must be greater than 0'
    });
  }

  if (!errors.length) {
    try {
      if (job) job.cancel();
      job = schedule.scheduleJob(`0 */24 * * *`, getAndCacheAllThreatActorNames(options));
    } catch (_) {}
  }

  cb(null, errors);
}
```

# Left-Right translation:
{ userOptions: _<@0, cb: _<@1,
  errors: [],

  # Validate API key
  {
    (userOptions@[\`apiKey\`][\`value\`] ?= `text`) ||
    ((userOptions@[\`apiKey\`][\`value\`] ?= `text`) && (userOptions@[\`apiKey\`][\`value\`] # = 0)):
      errors: errors + {
        key: `apiKey`,
        message: `You must provide a GTI API key`
      }
  ,

  # Validate max hashes per group
  {
    isNaN(userOptions@[\`maxHashesPerGroup\`][\`value\`]) ||
    (userOptions@[\`maxHashesPerGroup\`][\`value\`] <= 0):
      errors: errors + {
        key: `maxHashesPerGroup`,
        message: `Maximum number of hashes per lookup request must be greater than 0`
      }
  ,

  # Schedule threat actor cache job if no errors
  { errors # = 0:
    { job }: job.cancel(),
    job: schedule.scheduleJob(`0 */24 * * *`, getAndCacheAllThreatActorNames(options))
  ,

  cb(null, errors)
}

# ============================================================================
# getAndCacheAllThreatActorNames
# ============================================================================
# Original JS:
```javascript
const getAndCacheAllThreatActorNames =
  (options, cursor, agg = []) =>
  async () => {
    const searchResult = get(
      'body',
      await asyncRequestWithDefaults(
        {
          uri: 'https://www.virustotal.com/api/v3/collections',
          qs: {
            filter: `collection_type:threat-actor`,
            attributes: 'name',
            limit: 40,
            ...(cursor && { cursor })
          }
        },
        options
      )
    );

    const threatActorNames = flow(get('data'), map('attributes.name'))(searchResult);

    const nextCursor = get('meta.cursor', searchResult);
    const nextAgg = agg.concat(threatActorNames);

    if (nextCursor) {
      return getAndCacheAllThreatActorNames(options, nextCursor, nextAgg);
    }

    threatActorNames = flow(
      uniq,
      sortBy((name) => name.toLowerCase())
    )(nextAgg);
  };
```

# Left-Right translation:
